<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
  <title>운동 트래커</title>
  <link rel="manifest" href="manifest.json">
  <meta name="theme-color" content="#1a1a2e">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-title" content="운동">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, sans-serif;
      background: #111;
      color: #eee;
      min-height: 100vh;
      padding-bottom: 90px;
    }

    header {
      background: #1a1a2e;
      padding: 16px 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: 0 2px 8px rgba(0,0,0,0.5);
    }
    header h1 { font-size: 18px; font-weight: 700; }
    .date { font-size: 12px; color: #aaa; margin-top: 3px; }
    .intensity { font-size: 16px; letter-spacing: 2px; }

    .routine-tabs {
      display: flex;
      overflow-x: auto;
      background: #1a1a2e;
      border-bottom: 1px solid #2a2a3e;
      padding: 0 8px;
      scrollbar-width: none;
    }
    .routine-tabs::-webkit-scrollbar { display: none; }

    .tab {
      flex-shrink: 0;
      padding: 10px 16px;
      font-size: 13px;
      color: #666;
      border-bottom: 2px solid transparent;
      cursor: pointer;
      white-space: nowrap;
    }
    .tab.active { color: #7c83ff; border-bottom-color: #7c83ff; }
    .tab.today { color: #aaa; }

    .exercise-list { padding: 12px 16px; }

    .exercise-card {
      background: #1e1e2e;
      border-radius: 12px;
      margin-bottom: 12px;
      overflow: hidden;
    }

    .exercise-header {
      padding: 14px 16px 10px;
    }
    .exercise-name { font-size: 16px; font-weight: 600; }
    .exercise-meta { font-size: 12px; color: #888; margin-top: 4px; }
    .exercise-alt { font-size: 11px; color: #666; margin-top: 2px; }

    .sets-header {
      display: grid;
      grid-template-columns: 30px 1fr 1fr 38px;
      gap: 4px;
      padding: 6px 16px;
      font-size: 11px;
      color: #555;
      text-align: center;
      border-top: 1px solid #2a2a3e;
    }
    .sets-header span:first-child { text-align: left; }

    .set-row {
      display: grid;
      grid-template-columns: 30px 1fr 1fr 38px;
      gap: 4px;
      padding: 5px 16px;
      align-items: center;
      border-top: 1px solid #2a2a3e;
    }

    .set-num { font-size: 12px; color: #666; text-align: center; }

    .set-input {
      background: #2a2a3e;
      border: 1px solid #3a3a4e;
      border-radius: 8px;
      color: #eee;
      font-size: 15px;
      padding: 8px 4px;
      text-align: center;
      width: 100%;
      outline: none;
      -webkit-appearance: none;
    }
    .set-input:focus { border-color: #7c83ff; }
    .set-input::placeholder { color: #444; font-size: 13px; }

    .set-done {
      width: 30px;
      height: 30px;
      border-radius: 50%;
      border: 2px solid #3a3a4e;
      background: none;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      margin: 0 auto;
      color: transparent;
      font-size: 14px;
      transition: all 0.15s;
    }
    .set-done.checked {
      background: #4caf50;
      border-color: #4caf50;
      color: white;
    }

    .add-set-btn {
      display: block;
      width: calc(100% - 32px);
      margin: 8px 16px 14px;
      padding: 8px;
      background: none;
      border: 1px dashed #333;
      border-radius: 8px;
      color: #555;
      font-size: 13px;
      cursor: pointer;
    }
    .add-set-btn:active { background: #2a2a3e; }

    .rest-day {
      text-align: center;
      padding: 80px 20px;
      color: #555;
    }
    .rest-day .emoji { font-size: 48px; margin-bottom: 16px; }
    .rest-day p { font-size: 16px; }

    .bottom-bar {
      position: fixed;
      bottom: 0; left: 0; right: 0;
      padding: 12px 16px;
      background: #111;
      border-top: 1px solid #222;
      display: flex;
      gap: 10px;
    }

    .copy-btn {
      flex: 1;
      padding: 14px;
      border-radius: 12px;
      font-size: 16px;
      font-weight: 700;
      border: none;
      cursor: pointer;
      background: #7c83ff;
      color: white;
      transition: background 0.2s;
    }
    .copy-btn.copied { background: #4caf50; }
    .copy-btn:active { opacity: 0.85; }

    .reset-btn {
      padding: 14px 18px;
      border-radius: 12px;
      font-size: 14px;
      border: 1px solid #333;
      background: none;
      color: #777;
      cursor: pointer;
    }

    .toast {
      position: fixed;
      top: 70px;
      left: 50%;
      transform: translateX(-50%) translateY(-10px);
      background: #4caf50;
      color: white;
      padding: 10px 20px;
      border-radius: 20px;
      font-size: 14px;
      font-weight: 600;
      opacity: 0;
      transition: all 0.25s;
      pointer-events: none;
      z-index: 999;
      white-space: nowrap;
    }
    .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
  </style>
</head>
<body>

<header>
  <div>
    <h1 id="routineName">오늘 루틴</h1>
    <div class="date" id="todayDate"></div>
  </div>
  <div class="intensity" id="intensityStars"></div>
</header>

<div class="routine-tabs" id="routineTabs"></div>
<div class="exercise-list" id="exerciseList"></div>

<div class="bottom-bar">
  <button class="copy-btn" id="copyBtn" onclick="copyResult()">결과 복사</button>
  <button class="reset-btn" onclick="resetDay()">초기화</button>
</div>

<div class="toast" id="toast"></div>

<script>
const DAYS = ['일','월','화','수','목','금','토'];

const routines = {
  1: {
    name: 'Pull Heavy + 데드',
    intensity: '★★★',
    defaultSets: [4, 4, 3, 3, 3],
    exercises: [
      { name: '데드리프트', meta: '4세트 × 6-8회 · 휴식 3분', alt: '바벨 필수' },
      { name: '랫풀다운', meta: '4세트 × 10-12회 · 휴식 2분', alt: '대체: 턱걸이' },
      { name: '원암 덤벨 로우', meta: '3세트 × 10-12회 · 휴식 1.5분', alt: '대체: 케이블 로우' },
      { name: '암컬 머신', meta: '3세트 × 10-12회 · 휴식 1분', alt: '대체: 덤벨 컬' },
      { name: '행잉 니레이즈', meta: '3세트 × 10-15회 · 휴식 1분', alt: '' },
    ]
  },
  3: {
    name: 'Push',
    intensity: '★★',
    defaultSets: [4, 4, 3, 3],
    exercises: [
      { name: '머신 벤치', meta: '4세트 × 10-12회 · 휴식 2분', alt: '대체: 바벨 벤치 / 덤벨 프레스' },
      { name: '숄더프레스', meta: '4세트 × 10-12회 · 휴식 2분', alt: '대체: 덤벨 숄더프레스' },
      { name: '케이블 푸시다운', meta: '3세트 × 12-15회 · 휴식 1분', alt: '대체: 오버헤드 익스텐션' },
      { name: '사레레', meta: '3세트 × 12-15회 · 휴식 1분', alt: '' },
    ]
  },
  4: {
    name: 'Legs',
    intensity: '★★',
    defaultSets: [4, 3, 3, 3],
    exercises: [
      { name: '레그프레스', meta: '4세트 × 10-12회 · 휴식 2분', alt: '대체: 스쿼트' },
      { name: '레그컬', meta: '3세트 × 10-12회 · 휴식 1.5분', alt: '' },
      { name: '레그 익스텐션', meta: '3세트 × 10-12회 · 휴식 1.5분', alt: '' },
      { name: '행잉 니레이즈', meta: '3세트 × 10-15회 · 휴식 1분', alt: '' },
    ]
  },
  5: {
    name: 'Push Heavy',
    intensity: '★★★',
    defaultSets: [4, 4, 4, 3, 3],
    exercises: [
      { name: '머신 벤치', meta: '4세트 × 10-12회 · 휴식 2분', alt: '대체: 바벨 벤치' },
      { name: '숄더프레스', meta: '4세트 × 10-12회 · 휴식 2분', alt: '대체: 덤벨 숄더프레스' },
      { name: '케이블 푸시다운', meta: '4세트 × 12-15회 · 휴식 1분', alt: '대체: 오버헤드 익스텐션' },
      { name: '사레레', meta: '3세트 × 12-15회 · 휴식 1분', alt: '' },
      { name: '행잉 니레이즈', meta: '3세트 × 10-15회 · 휴식 1분', alt: '' },
    ]
  }
};

let state = {};
try { state = JSON.parse(localStorage.getItem('workoutState') || '{}'); } catch(e) {}

const today = new Date().getDay();
let selectedDay = routines[today] ? today : 1;

function init() {
  const now = new Date();
  document.getElementById('todayDate').textContent =
    `${now.getFullYear()}.${now.getMonth()+1}.${now.getDate()} (${DAYS[now.getDay()]})`;
  renderTabs();
  renderRoutine(selectedDay);
}

function renderTabs() {
  const tabs = document.getElementById('routineTabs');
  tabs.innerHTML = '';
  [0,1,2,3,4,5,6].forEach(d => {
    const tab = document.createElement('div');
    tab.className = 'tab' + (d === selectedDay ? ' active' : '') + (d === today ? ' today' : '');
    tab.textContent = DAYS[d] + (routines[d] ? '' : '');
    tab.onclick = () => { selectedDay = d; renderTabs(); renderRoutine(d); };
    tabs.appendChild(tab);
  });
}

function dayState(d) {
  if (!state[d]) state[d] = {};
  return state[d];
}

function renderRoutine(day) {
  const list = document.getElementById('exerciseList');
  const routine = routines[day];

  if (!routine) {
    document.getElementById('routineName').textContent = '휴식일';
    document.getElementById('intensityStars').textContent = '';
    list.innerHTML = `<div class="rest-day"><div class="emoji">😴</div><p>오늘은 완전 휴식</p></div>`;
    return;
  }

  document.getElementById('routineName').textContent = routine.name;
  document.getElementById('intensityStars').textContent = routine.intensity;

  const ds = dayState(day);
  list.innerHTML = '';

  routine.exercises.forEach((ex, ei) => {
    if (!ds[ex.name]) {
      ds[ex.name] = Array.from({length: routine.defaultSets[ei]}, () => ({w:'',r:'',done:false}));
    }

    const card = document.createElement('div');
    card.className = 'exercise-card';
    card.innerHTML = `
      <div class="exercise-header">
        <div class="exercise-name">${ex.name}</div>
        <div class="exercise-meta">${ex.meta}</div>
        ${ex.alt ? `<div class="exercise-alt">${ex.alt}</div>` : ''}
      </div>
      <div class="sets-header">
        <span>세트</span><span>무게</span><span>횟수</span><span></span>
      </div>
      <div id="rows-${day}-${ei}"></div>
      <button class="add-set-btn" onclick="addSet(${day},'${ex.name}',${ei})">+ 세트 추가</button>
    `;
    list.appendChild(card);
    renderRows(day, ex.name, ei);
  });
}

function renderRows(day, exName, ei) {
  const container = document.getElementById(`rows-${day}-${ei}`);
  if (!container) return;
  const sets = dayState(day)[exName];
  container.innerHTML = '';
  sets.forEach((s, i) => {
    const row = document.createElement('div');
    row.className = 'set-row';
    row.innerHTML = `
      <div class="set-num">${i+1}</div>
      <input class="set-input" type="text" inputmode="decimal" placeholder="무게/핀"
        value="${s.w}" onchange="upd(${day},'${exName}',${i},'w',this.value)">
      <input class="set-input" type="number" inputmode="numeric" placeholder="횟수"
        value="${s.r}" onchange="upd(${day},'${exName}',${i},'r',this.value)">
      <button class="set-done${s.done?' checked':''}"
        onclick="toggleDone(${day},'${exName}',${i},${ei})">✓</button>
    `;
    container.appendChild(row);
  });
}

function upd(day, name, i, field, val) {
  dayState(day)[name][i][field] = val;
  save();
}

function toggleDone(day, name, i, ei) {
  const s = dayState(day)[name][i];
  s.done = !s.done;
  save();
  renderRows(day, name, ei);
}

function addSet(day, name, ei) {
  dayState(day)[name].push({w:'',r:'',done:false});
  save();
  renderRows(day, name, ei);
}

function save() {
  localStorage.setItem('workoutState', JSON.stringify(state));
}

function resetDay() {
  if (!confirm('오늘 기록을 초기화할까요?')) return;
  state[selectedDay] = {};
  save();
  renderRoutine(selectedDay);
}

function copyResult() {
  const routine = routines[selectedDay];
  if (!routine) return;

  const now = new Date();
  const d = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}-${String(now.getDate()).padStart(2,'0')}`;
  const ds = dayState(selectedDay);

  let lines = [`${d} 운동 (${routine.name})\n`];
  routine.exercises.forEach(ex => {
    const sets = (ds[ex.name] || []).filter(s => s.w || s.r || s.done);
    if (!sets.length) return;
    const detail = sets.map(s => `${s.w||'-'}×${s.r||'-'}`).join(', ');
    lines.push(`- ${ex.name}: ${sets.length}세트 (${detail})`);
  });

  const text = lines.join('\n');

  const copy = (t) => {
    const btn = document.getElementById('copyBtn');
    btn.textContent = '복사됨!';
    btn.classList.add('copied');
    showToast('복사됨! Claude에 붙여넣기');
    setTimeout(() => { btn.textContent = '결과 복사'; btn.classList.remove('copied'); }, 2000);
  };

  if (navigator.clipboard) {
    navigator.clipboard.writeText(text).then(copy).catch(() => fallbackCopy(text, copy));
  } else {
    fallbackCopy(text, copy);
  }
}

function fallbackCopy(text, cb) {
  const ta = document.createElement('textarea');
  ta.value = text; ta.style.position = 'fixed'; ta.style.opacity = '0';
  document.body.appendChild(ta); ta.focus(); ta.select();
  try { document.execCommand('copy'); cb(); } catch(e) {}
  document.body.removeChild(ta);
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2500);
}

if ('serviceWorker' in navigator) {
  navigator.serviceWorker.register('sw.js').catch(() => {});
}

init();
</script>
</body>
</html>
